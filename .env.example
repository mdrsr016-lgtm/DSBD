# ============================================================
# Firebase Environment Variables
# ============================================================
#
# LOCAL: Copy this file to .env and fill in your credentials
#        cp .env.example .env
#
# VERCEL: Add these in Vercel Dashboard → Settings → Environment Variables
#         Variables MUST start with VITE_ to be available in the browser
#
# Get values from:
#   https://console.firebase.google.com
#   → Your Project → Project Settings → Your Apps → Web App → SDK config
# ============================================================

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
